.tag-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 50rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.tag-item.selected {
  background: linear-gradient(135deg, #667eea22, #764ba222);
  color: #667eea;
  border-color: #667eea;
}

.tag-icon {
  font-size: 28rpx;
}

.tag-name {
  font-weight: 500;
}