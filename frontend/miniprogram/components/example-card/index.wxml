<view class="example-card">
  <view class="card-icon">{{item.icon}}</view>
  <view class="card-body">
    <text class="card-name">{{item.name}}</text>
    <text class="card-prompt">{{item.prompt}}</text>
    <view class="card-tags">
      <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
  </view>
  <button class="card-btn" bindtap="onUse" data-example="{{item}}">使用</button>
</view>