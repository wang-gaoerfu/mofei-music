.player {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(102,126,234,0.2);
  overflow: hidden;
}

.player-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
}

.player-icon {
  font-size: 36rpx;
}

.player-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.player-main {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 封面 */
.cover-section {
  margin-bottom: 30rpx;
}

.cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(102,126,234,0.4);
  position: relative;
}

.cover::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx dashed rgba(255,255,255,0.3);
}

.cover.spinning {
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.cover-icon {
  font-size: 80rpx;
}

/* 进度条 */
.progress-section {
  width: 100%;
  margin-bottom: 20rpx;
}

.progress-slider {
  width: 100%;
  margin: 0;
}

.time-display {
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
  margin-top: -10rpx;
}

.time-text {
  font-size: 22rpx;
  color: #999;
}

/* 控制按钮 */
.controls-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #f5f5f5;
}

.control-icon {
  font-size: 32rpx;
}

.play-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 4rpx 20rpx rgba(102,126,234,0.4);
}

.play-icon {
  font-size: 44rpx;
  color: #fff;
}

/* 操作按钮 */
.actions-section {
  display: flex;
  gap: 30rpx;
  width: 100%;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}