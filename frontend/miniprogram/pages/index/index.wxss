.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 180rpx;
}

/* Header */
.header {
  padding: 40rpx 30rpx 20rpx;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.logo-text {
  font-size: 72rpx;
}

.title-group {
  display: flex;
  flex-direction: column;
}

.main-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.sub-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  margin: 10rpx 30rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  display: block;
}

.user-credits {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
  display: block;
}

.arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.7);
}

/* 分类 Tab */
.category-tabs {
  padding: 20rpx 0 10rpx;
}

.tabs-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.tab {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  margin: 0 8rpx;
  border-radius: 50rpx;
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.tab.active {
  background: #fff;
  color: #667eea;
  border-color: rgba(255,255,255,0.5);
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.1);
}

.tab-icon {
  font-size: 28rpx;
}

.tab-name {
  font-weight: 500;
}

/* 示例列表 */
.example-list {
  height: calc(100vh - 480rpx);
  padding: 10rpx 20rpx;
}

.example-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.example-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea22, #764ba222);
  border-radius: 16rpx;
}

.card-title-group {
  flex: 1;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.card-category {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.card-prompt {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tag {
  display: inline-block;
  background: linear-gradient(135deg, #667eea11, #764ba211);
  color: #667eea;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin: 4rpx 4rpx 4rpx 0;
}

.use-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 18rpx 0;
  font-weight: 500;
}

.use-btn::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.create-btn,
.library-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 50rpx;
  border: none;
}

.create-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(102,126,234,0.4);
}

.library-btn {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.btn-icon {
  font-size: 32rpx;
}

.create-btn::after,
.library-btn::after {
  border: none;
}