<view class="container">
  <!-- 顶部 Header -->
  <view class="header">
    <view class="logo-section">
      <text class="logo-text">🎵</text>
      <view class="title-group">
        <text class="main-title">音乐创作</text>
        <text class="sub-title">免费创作 · 下载付费</text>
      </view>
    </view>
  </view>

  <!-- 用户信息栏 -->
  <view class="user-bar" bindtap="goUser">
    <view class="user-avatar">
      <text>{{userInfo.nickname || '用户'}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickname || '游客'}}</text>
      <text class="user-credits">下载余额 {{balance}} 次</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- 分类 Tab -->
  <view class="category-tabs">
    <scroll-view scroll-x class="tabs-scroll">
      <view wx:for="{{categories}}" wx:key="value"
            class="tab {{activeCategory === item.value ? 'active' : ''}}"
            bindtap="switchCategory"
            data-value="{{item.value}}">
        <text class="tab-name">{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 公共曲库列表 -->
  <scroll-view scroll-y class="music-list" enhanced show-scrollbar="false" bindscrolltolower="loadMore">
    <view wx:if="{{publicList.length > 0}}">
      <view wx:for="{{publicList}}" wx:key="uuid" class="music-item">
        <view class="music-cover" bindtap="playMusic" data-music="{{item}}">
          <text class="cover-icon">🎵</text>
        </view>
        <view class="music-info">
          <text class="music-title">{{item.title}}</text>
          <text class="music-author">@{{item.author_nickname}}</text>
          <view class="music-meta">
            <text class="download-count">📥 {{item.download_count}}</text>
          </view>
        </view>
        <view class="music-actions">
          <button class="play-btn" bindtap="playMusic" data-music="{{item}}">▶</button>
          <button class="download-btn" bindtap="downloadMusic" data-uuid="{{item.uuid}}" data-music="{{item}}">下载</button>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{publicList.length === 0 && !isLoading}}" class="empty-state">
      <text class="empty-icon">🎶</text>
      <text class="empty-text">公共曲库为空</text>
      <text class="empty-hint">成为第一个发布歌曲的人吧！</text>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{isLoading}}" class="loading-more">
      <text>加载中...</text>
    </view>

    <view wx:if="{{!hasMore && publicList.length > 0}}" class="no-more">
      <text>— 没有更多了 —</text>
    </view>
  </scroll-view>

  <!-- 底部快捷入口 -->
  <view class="bottom-bar">
    <button class="create-btn" bindtap="goCreate">
      <text class="btn-icon">🎵</text>
      <text>开始创作</text>
    </button>
    <button class="library-btn" bindtap="goLibrary">
      <text class="btn-icon">🎧</text>
      <text>我的曲库</text>
    </button>
  </view>
</view>