.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9ff 0%, #eef0ff 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 页面标题 */
.page-header {
  padding: 40rpx 30rpx 10rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 筛选 Tab */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 10rpx 30rpx 20rpx;
}

.filter-tab {
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  transition: all 0.3s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: transparent;
}

/* 音乐列表 */
.music-list {
  height: calc(100vh - 200rpx);
  padding: 0 20rpx;
}

.music-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(102,126,234,0.08);
}

.music-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.music-cover {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cover-icon {
  font-size: 40rpx;
}

.generating-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.generating-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #fff;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(0.8); opacity: 0.5; }
  50% { transform: scale(1.2); opacity: 1; }
}

.music-detail {
  flex: 1;
  min-width: 0;
}

.music-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.music-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 6rpx;
}

.music-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.music-status.status-completed {
  background: #e6f7ed;
  color: #52c41a;
}

.music-status.status-generating {
  background: #fff7e6;
  color: #faad14;
}

.music-status.status-failed {
  background: #fff1f0;
  color: #ff4d4f;
}

.music-time {
  font-size: 22rpx;
  color: #bbb;
}

.music-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.mini-tag {
  font-size: 20rpx;
  color: #667eea;
  background: #667eea11;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}

/* 操作按钮 */
.music-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.start-create-btn {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

.start-create-btn::after {
  border: none;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 4rpx solid #667eea33;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 正在播放浮层 */
.playing-float {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 30rpx rgba(102,126,234,0.5);
}

.float-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.float-icon {
  font-size: 32rpx;
}

.float-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.float-status {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}